    "extract_dir": "Sonarr",
    "post_install": [
        "$WSshell = New-Object -ComObject WScript.Shell",
        "$shortcut = $WSshell.CreateShortcut(\"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\Sonarr.lnk\")",
        "$shortcut.TargetPath = \"$dir\\Sonarr.exe\"",
        "$shortcut.Save()"
